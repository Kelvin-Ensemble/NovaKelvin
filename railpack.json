{
  "$schema": "https://railway.com/railway.schema.json",
  "buildAptPackages": ["xmlsec1", "libxmlsec1-dev", "pkg-config", "libssl-dev"]
  "build": {
    "builder": "RAILPACK",
    "buildEnvironment": "V3"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "startCommand": "python manage.py collectstatic --noinput && gunicorn NovaKelvin.wsgi:application --bind 0.0.0.0:8000",
    "sleepApplication": false,
    "useLegacyStacker": false,
    "ipv6EgressEnabled": false,
    "multiRegionConfig": {
      "europe-west4-drams3a": {
        "numReplicas": 1
      }
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}